diff --git a/CMakeLists.txt b/CMakeLists.txt
index 7344d08..20f1164 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -245,12 +245,24 @@ else(ROS_EDITION STREQUAL "ROS2")
     LIBRARY_NAME ${PROJECT_NAME}
   )
 
+  set(LIVOX_SDK2_ROOT "$ENV{LIVOX_SDK2_ROOT}" CACHE PATH "Livox-SDK2 install prefix")
+  set(LIVOX_SDK2_LIBRARY_PATHS /usr/local/lib)
+  set(LIVOX_SDK2_INCLUDE_PATHS /usr/local/include)
+  if(LIVOX_SDK2_ROOT)
+    list(PREPEND LIVOX_SDK2_LIBRARY_PATHS "${LIVOX_SDK2_ROOT}/lib")
+    list(PREPEND LIVOX_SDK2_INCLUDE_PATHS "${LIVOX_SDK2_ROOT}/include")
+  endif()
+
   ## make sure the livox_lidar_sdk_shared library is installed
-  find_library(LIVOX_LIDAR_SDK_LIBRARY liblivox_lidar_sdk_shared.so /usr/local/lib REQUIRED)
+  find_library(LIVOX_LIDAR_SDK_LIBRARY
+    NAMES livox_lidar_sdk_shared liblivox_lidar_sdk_shared.so
+    PATHS ${LIVOX_SDK2_LIBRARY_PATHS}
+    REQUIRED)
 
   ##
   find_path(LIVOX_LIDAR_SDK_INCLUDE_DIR
     NAMES "livox_lidar_api.h" "livox_lidar_def.h"
+    PATHS ${LIVOX_SDK2_INCLUDE_PATHS}
     REQUIRED)
 
   ## PCL library
@@ -282,15 +294,19 @@ else(ROS_EDITION STREQUAL "ROS2")
   target_include_directories(${PROJECT_NAME} PRIVATE ${livox_sdk_INCLUDE_DIRS})
 
   # get include directories of custom msg headers
-  if(DISTRO_ROS STREQUAL "humble" OR DISTRO_ROS STREQUAL "jazzy")
+  if("$ENV{ROS_DISTRO}" STREQUAL "humble" OR "$ENV{ROS_DISTRO}" STREQUAL "jazzy")
     rosidl_get_typesupport_target(cpp_typesupport_target
     ${LIVOX_INTERFACES} "rosidl_typesupport_cpp")
     target_link_libraries(${PROJECT_NAME} "${cpp_typesupport_target}")
+    set(LIVOX_INTERFACES_INCLUDE_DIRECTORIES "")
   else()
     set(LIVOX_INTERFACE_TARGET "${LIVOX_INTERFACES}__rosidl_typesupport_cpp")
     add_dependencies(${PROJECT_NAME} ${LIVOX_INTERFACES})
     get_target_property(LIVOX_INTERFACES_INCLUDE_DIRECTORIES ${LIVOX_INTERFACE_TARGET} INTERFACE_INCLUDE_DIRECTORIES)
   endif()
+  if(NOT LIVOX_INTERFACES_INCLUDE_DIRECTORIES)
+    set(LIVOX_INTERFACES_INCLUDE_DIRECTORIES "")
+  endif()
 
   # include file direcotry
   target_include_directories(${PROJECT_NAME} PUBLIC
@@ -333,4 +349,4 @@ else(ROS_EDITION STREQUAL "ROS2")
     launch_ROS2
   )
 
-endif()
\ No newline at end of file
+endif()
