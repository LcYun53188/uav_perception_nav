#!/usr/bin/env bash
# Central navigation launch/debug defaults.
#
# Edit this file for the usual field mode, then run scripts without repeatedly
# typing long option lists. Command-line options still override these values.

# UAV navigation stack: scripts/run_nav_stack.sh
NAV_ODOM_SOURCE="${NAV_ODOM_SOURCE:-vio}"             # vio | lio | both
NAV_POINTCLOUD_SOURCE="${NAV_POINTCLOUD_SOURCE:-oakd}"  # oakd | mid360 | both
NAV_ENABLE_GPS="${NAV_ENABLE_GPS:-false}"             # true | false
if ! declare -p NAV_EXTRA_ARGS >/dev/null 2>&1; then
  NAV_EXTRA_ARGS=()
fi

# Ground omni-wheel stack: scripts/run_omni_nav.sh
OMNI_POINTCLOUD_SOURCE="${OMNI_POINTCLOUD_SOURCE:-oakd}"  # oakd | mid360 | both
OMNI_ENABLE_BRIDGE="${OMNI_ENABLE_BRIDGE:-false}"         # true | false
OMNI_PLANNER="${OMNI_PLANNER:-se2_dwa}"                   # se2_dwa | dwb
OMNI_ENABLE_OFFLINE_MAP="${OMNI_ENABLE_OFFLINE_MAP:-false}"  # true | false
OMNI_OFFLINE_MAP_YAML="${OMNI_OFFLINE_MAP_YAML:-}"
if ! declare -p OMNI_EXTRA_ARGS >/dev/null 2>&1; then
  OMNI_EXTRA_ARGS=()
fi

# Debug checks.
DEBUG_TIMEOUT_SEC="${DEBUG_TIMEOUT_SEC:-4}"
CHECK_NAV_PX4="${CHECK_NAV_PX4:-false}"
CHECK_NAV_MID360="${CHECK_NAV_MID360:-false}"
CHECK_OMNI_BRIDGE="${CHECK_OMNI_BRIDGE:-false}"
CHECK_OMNI_OFFLINE_MAP="${CHECK_OMNI_OFFLINE_MAP:-false}"
OFFLINE_MAP_EXPECTED_FRAME="${OFFLINE_MAP_EXPECTED_FRAME:-map}"

# Bag / visualization helpers.
BAG_OUTPUT="${BAG_OUTPUT:-}"
BAG_INCLUDE_OFFLINE_MAP="${BAG_INCLUDE_OFFLINE_MAP:-false}"
BAG_INCLUDE_OMNI="${BAG_INCLUDE_OMNI:-false}"
if ! declare -p BAG_EXTRA_TOPICS >/dev/null 2>&1; then
  BAG_EXTRA_TOPICS=()
fi
RVIZ_FIXED_FRAME="${RVIZ_FIXED_FRAME:-map}"
